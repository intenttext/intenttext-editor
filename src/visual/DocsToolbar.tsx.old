// Google Docs-style toolbar for the visual editor
// Paragraph style dropdown, insert menu, undo/redo

import { useState, useRef, useEffect, useCallback } from "react";
import type { Editor } from "@tiptap/core";

interface Props {
  editor: Editor | null;
}

// Style options that map to IT keywords
const STYLE_OPTIONS = [
  { label: "Normal text", node: "paragraph", icon: "" },
  { label: "Title", node: "itTitle", icon: "" },
  { label: "Section", node: "itSection", icon: "" },
  { label: "Subsection", node: "itSub", icon: "" },
  { label: "Summary", node: "itSummary", icon: "" },
  { label: "Quote", node: "itQuote", icon: "❝" },
] as const;

const INSERT_OPTIONS = [
  { label: "Divider", keyword: "divider", icon: "―" },
  { label: "Page break", keyword: "break", icon: "⎘" },
  { label: "Code block", keyword: "code", icon: "</>" },
  { label: "Tip", keyword: "tip", icon: "💡" },
  { label: "Info", keyword: "info", icon: "ℹ️" },
  { label: "Warning", keyword: "warning", icon: "⚠️" },
  { label: "Danger", keyword: "danger", icon: "🚨" },
  { label: "Success", keyword: "success", icon: "✅" },
  { label: "Image", keyword: "image", icon: "🖼" },
  { label: "Link", keyword: "link", icon: "🔗" },
  { label: "Contact", keyword: "contact", icon: "👤" },
  { label: "Metric", keyword: "metric", icon: "📊" },
  { label: "Deadline", keyword: "deadline", icon: "📅" },
  { label: "Definition", keyword: "def", icon: "📖" },
] as const;

export function DocsToolbar({ editor }: Props) {
  const [styleOpen, setStyleOpen] = useState(false);
  const [insertOpen, setInsertOpen] = useState(false);
  const styleRef = useRef<HTMLDivElement>(null);
  const insertRef = useRef<HTMLDivElement>(null);

  // Close dropdowns on outside click
  useEffect(() => {
    const handler = (e: MouseEvent) => {
      if (styleRef.current && !styleRef.current.contains(e.target as Node)) {
        setStyleOpen(false);
      }
      if (insertRef.current && !insertRef.current.contains(e.target as Node)) {
        setInsertOpen(false);
      }
    };
    document.addEventListener("mousedown", handler);
    return () => document.removeEventListener("mousedown", handler);
  }, []);

  const getCurrentStyle = useCallback((): string => {
    if (!editor) return "Normal text";
    for (const opt of STYLE_OPTIONS) {
      if (opt.node === "paragraph" && editor.isActive("paragraph")) {
        // Check it's not a more specific type
        const isOther = STYLE_OPTIONS.some(
          (o) => o.node !== "paragraph" && editor.isActive(o.node),
        );
        if (!isOther) return opt.label;
      } else if (editor.isActive(opt.node)) {
        return opt.label;
      }
    }
    return "Normal text";
  }, [editor]);

  const setStyle = useCallback(
    (nodeType: string) => {
      if (!editor) return;
      editor.chain().focus();
      if (nodeType === "paragraph") {
        editor.chain().focus().setParagraph().run();
      } else if (nodeType === "itCallout") {
        editor.chain().focus().setNode("itCallout", { variant: "tip" }).run();
      } else if (nodeType === "itQuote") {
        editor.chain().focus().setNode("itQuote").run();
      } else {
        editor.chain().focus().setNode(nodeType).run();
      }
      setStyleOpen(false);
    },
    [editor],
  );

  const insertBlock = useCallback(
    (keyword: string) => {
      if (!editor) return;
      const chain = editor.chain().focus();

      if (keyword === "divider") {
        chain.setNode("itDivider").run();
      } else if (keyword === "break") {
        chain.setNode("itBreak").run();
      } else if (keyword === "code") {
        chain.setNode("itCode", { lang: "" }).run();
      } else if (
        ["tip", "info", "warning", "danger", "success"].includes(keyword)
      ) {
        chain.setNode("itCallout", { variant: keyword }).run();
      } else {
        // Generic block for image, link, contact, metric, etc.
        chain.setNode("itGenericBlock", { keyword, properties: "" }).run();
      }
      setInsertOpen(false);
    },
    [editor],
  );

  if (!editor) return null;

  return (
    <div className="docs-toolbar">
      {/* Undo / Redo */}
      <button
        className="docs-tb-btn"
        onClick={() => editor.chain().focus().undo().run()}
        disabled={!editor.can().undo()}
        title="Undo (Cmd+Z)"
      >
        <svg
          viewBox="0 0 24 24"
          width="18"
          height="18"
          fill="none"
          stroke="currentColor"
          strokeWidth="2"
        >
          <polyline points="1 4 1 10 7 10" />
          <path d="M3.51 15a9 9 0 1 0 2.13-9.36L1 10" />
        </svg>
      </button>
      <button
        className="docs-tb-btn"
        onClick={() => editor.chain().focus().redo().run()}
        disabled={!editor.can().redo()}
        title="Redo (Cmd+Shift+Z)"
      >
        <svg
          viewBox="0 0 24 24"
          width="18"
          height="18"
          fill="none"
          stroke="currentColor"
          strokeWidth="2"
        >
          <polyline points="23 4 23 10 17 10" />
          <path d="M20.49 15a9 9 0 1 1-2.12-9.36L23 10" />
        </svg>
      </button>

      <div className="docs-tb-sep" />

      {/* Paragraph style dropdown — Google Docs style */}
      <div className="docs-tb-dropdown" ref={styleRef}>
        <button
          className="docs-tb-style-btn"
          onClick={() => {
            setStyleOpen(!styleOpen);
            setInsertOpen(false);
          }}
        >
          <span>{getCurrentStyle()}</span>
          <svg viewBox="0 0 24 24" width="16" height="16" fill="currentColor">
            <path d="M7 10l5 5 5-5z" />
          </svg>
        </button>
        {styleOpen && (
          <div className="docs-tb-dropdown-menu docs-style-menu">
            {STYLE_OPTIONS.map((opt) => (
              <button
                key={opt.node}
                className={`docs-tb-dropdown-item ${getCurrentStyle() === opt.label ? "active" : ""}`}
                onClick={() => setStyle(opt.node)}
              >
                <span className={`docs-style-preview docs-style-${opt.node}`}>
                  {opt.label}
                </span>
              </button>
            ))}
          </div>
        )}
      </div>

      <div className="docs-tb-sep" />

      {/* Insert dropdown */}
      <div className="docs-tb-dropdown" ref={insertRef}>
        <button
          className="docs-tb-btn docs-tb-insert-btn"
          onClick={() => {
            setInsertOpen(!insertOpen);
            setStyleOpen(false);
          }}
          title="Insert"
        >
          <svg
            viewBox="0 0 24 24"
            width="18"
            height="18"
            fill="none"
            stroke="currentColor"
            strokeWidth="2"
          >
            <line x1="12" y1="5" x2="12" y2="19" />
            <line x1="5" y1="12" x2="19" y2="12" />
          </svg>
          Insert
          <svg viewBox="0 0 24 24" width="14" height="14" fill="currentColor">
            <path d="M7 10l5 5 5-5z" />
          </svg>
        </button>
        {insertOpen && (
          <div className="docs-tb-dropdown-menu docs-insert-menu">
            {INSERT_OPTIONS.map((opt) => (
              <button
                key={opt.keyword}
                className="docs-tb-dropdown-item"
                onClick={() => insertBlock(opt.keyword)}
              >
                <span className="docs-insert-icon">{opt.icon}</span>
                <span>{opt.label}</span>
              </button>
            ))}
          </div>
        )}
      </div>
    </div>
  );
}
