<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>IntentText Editor</title>
    <meta
      name="description"
      content="A professional WYSIWYG editor for IntentText (.it) documents. Write structured documents with clean syntax underneath."
    />
    <link rel="icon" type="image/png" href="/favicon.ico" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500;600&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <div class="it-app">
      <!-- ── Header ─────────────────────────────────────── -->
      <header class="it-header">
        <div class="it-header__logo">Intent<span>Text</span> Editor</div>
        <div class="it-header__actions">
          <button class="it-btn" id="btn-new" title="New document (Ctrl+N)">
            + New
          </button>
          <button class="it-btn" id="btn-open" title="Open file (Ctrl+O)">
            Open
          </button>
          <button class="it-btn" id="btn-save" title="Save file (Ctrl+S)">
            Save
          </button>
          <div class="it-dropdown" id="export-dropdown">
            <button class="it-btn it-btn--primary" id="btn-export">
              Export ▾
            </button>
            <div class="it-dropdown__menu" id="export-menu">
              <button class="it-dropdown__item" data-export="it">
                Download .it file
              </button>
              <button class="it-dropdown__item" data-export="json">
                Download JSON
              </button>
              <button class="it-dropdown__item" data-export="html">
                Download HTML
              </button>
              <button class="it-dropdown__item" data-export="print">
                Download Print HTML
              </button>
              <div class="it-dropdown__divider"></div>
              <button class="it-dropdown__item" data-export="copy-it">
                Copy .it to clipboard
              </button>
              <button class="it-dropdown__item" data-export="copy-json">
                Copy JSON to clipboard
              </button>
              <div class="it-dropdown__divider"></div>
              <button class="it-dropdown__item" data-export="pdf">
                Print / PDF
              </button>
            </div>
          </div>
          <a
            class="it-header__link"
            href="convert.html"
            title="Conversion tools"
            >Tools →</a
          >
        </div>
      </header>

      <!-- ── Tab Bar ────────────────────────────────────── -->
      <div class="it-tabbar">
        <button class="it-tab active" data-tab="edit">✎ Edit</button>
        <button class="it-tab" data-tab="source">&lt; &gt; Source</button>
        <button class="it-tab" data-tab="json">{ } JSON</button>
        <button class="it-tab" data-tab="print">⎙ Print</button>
      </div>

      <!-- ── Block Toolbar (fixed, for edit tab) ────────── -->
      <div class="it-block-toolbar" id="block-toolbar">
        <button class="it-btn" data-action="add-block" title="Add block">
          + Block
        </button>
        <button class="it-btn" data-action="move-up" title="Move up (Alt+↑)">
          ↑
        </button>
        <button
          class="it-btn"
          data-action="move-down"
          title="Move down (Alt+↓)"
        >
          ↓
        </button>
        <button class="it-btn" data-action="delete-block" title="Delete block">
          ⌫
        </button>
        <span class="it-toolbar-sep"></span>
        <button
          class="it-btn it-btn--fmt"
          data-format="bold"
          title="Bold (Ctrl+B)"
        >
          <strong>B</strong>
        </button>
        <button
          class="it-btn it-btn--fmt"
          data-format="italic"
          title="Italic (Ctrl+I)"
        >
          <em>I</em>
        </button>
        <button
          class="it-btn it-btn--fmt"
          data-format="strike"
          title="Strikethrough (Ctrl+Shift+X)"
        >
          <s>S</s>
        </button>
        <button
          class="it-btn it-btn--fmt"
          data-format="highlight"
          title="Highlight"
        >
          ^H
        </button>
        <button
          class="it-btn it-btn--fmt"
          data-format="code"
          title="Inline code"
        >
          `C`
        </button>
        <button
          class="it-btn it-btn--fmt"
          data-format="link"
          title="Link (Ctrl+K)"
        >
          🔗
        </button>
        <button
          class="it-btn it-btn--fmt"
          data-format="clear"
          title="Clear formatting"
        >
          ✕
        </button>
        <span class="it-toolbar-sep"></span>
        <button
          class="it-btn it-btn--kw"
          data-type="title"
          title="Title (Ctrl+1)"
        >
          Title
        </button>
        <button
          class="it-btn it-btn--kw"
          data-type="section"
          title="Section (Ctrl+2)"
        >
          Section
        </button>
        <button class="it-btn it-btn--kw" data-type="note" title="Note">
          Note
        </button>
        <button class="it-btn it-btn--kw" data-type="task" title="Task">
          Task
        </button>
        <button class="it-btn it-btn--kw" data-type="quote" title="Quote">
          Quote
        </button>
        <button class="it-btn it-btn--kw" data-type="info" title="Info">
          Info
        </button>
        <button class="it-btn it-btn--kw" data-type="warning" title="Warning">
          Warn
        </button>
        <button class="it-btn it-btn--kw" data-type="step" title="Step">
          Step
        </button>
        <button class="it-btn it-btn--kw" data-type="code" title="Code">
          Code
        </button>
        <button class="it-btn it-btn--kw" data-type="divider" title="Divider">
          ---
        </button>
      </div>

      <!-- ── Restore Banner ─────────────────────────────── -->
      <div class="it-restore-banner hidden" id="restore-banner">
        <span
          >💾 Unsaved document found from
          <span class="restore-age">a moment</span> ago.</span
        >
        <button class="restore-yes">Restore</button>
        <button class="restore-no">Discard</button>
      </div>

      <!-- ── Content Area (tab panels) ──────────────────── -->
      <div class="it-content">
        <div class="it-tab-panel" id="tab-edit"></div>
        <div class="it-tab-panel hidden" id="tab-source"></div>
        <div class="it-tab-panel hidden" id="tab-json"></div>
        <div class="it-tab-panel hidden" id="tab-print"></div>
      </div>

      <!-- ── Status Bar ─────────────────────────────────── -->
      <footer class="it-statusbar">
        <div class="it-statusbar__left">
          <span id="status-stats">blocks: 0 · words: 0 · lines: 0</span>
        </div>
        <div class="it-statusbar__right">
          <span id="status-message"></span>
        </div>
      </footer>
    </div>

    <script type="module" src="/src/editor-main.ts"></script>
  </body>
</html>
